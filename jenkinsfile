pipeline {
    agent any

    environment {
        IMAGE_NAME = "Oredollar/new-time-app-clock-app"
    }

    stages {

        stage('Clone') {
            steps {
                git 'https://github.com/oredollars/new-time-app.git'
            }
        }

        stage('Build Docker Image') {
            steps {
                sh 'docker build -t $IMAGE_NAME:v1 .'
            }
        }

        stage('Push Docker Image') {
            steps {
                sh 'docker push $IMAGE_NAME:v1'
            }
        }

    }
}